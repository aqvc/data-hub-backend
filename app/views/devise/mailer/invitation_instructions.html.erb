<% frontend_host = ENV.fetch("FRONTEND_URL", "http://localhost:3101") %>
<% invitation_url = "#{frontend_host}/auth/accept-invitation?invitation_token=#{@token}" %>

<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; background-color: #ffffff;">
  <div style="background-color: #0f172a; padding: 32px; text-align: center;">
    <h1 style="color: #ffffff; margin: 0; font-size: 24px; font-weight: 700;">AQVC Hub</h1>
  </div>
  <div style="padding: 40px 32px;">
    <h2 style="font-size: 20px; margin: 0 0 16px; color: #0f172a;">You're invited!</h2>
    <p style="margin: 0 0 16px; font-size: 15px; color: #475569;">Hi <%= @resource.first_name %>,</p>
    <p style="margin: 0 0 16px; font-size: 15px; color: #475569;">
      <% if @resource.invited_by %>
        <%= @resource.invited_by.first_name %> <%= @resource.invited_by.last_name %> has invited you to join <strong>AQVC Hub</strong>.
      <% else %>
        You've been invited to join <strong>AQVC Hub</strong>.
      <% end %>
      Click the button below to set up your account.
    </p>
    <p style="margin: 8px 0 24px;">
      <a href="<%= invitation_url %>" style="display: inline-block; padding: 12px 32px; background-color: #0f172a; color: #ffffff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 15px;">Accept Invitation</a>
    </p>
    <p style="margin: 0 0 16px; font-size: 15px; color: #475569;">This invitation will expire in <%= distance_of_time_in_words(User.invite_for) %>. If you didn't expect this invitation, you can safely ignore this email.</p>
  </div>
  <div style="padding: 24px 32px; text-align: center; border-top: 1px solid #e2e8f0;">
    <p style="font-size: 13px; color: #94a3b8; margin: 0;">&copy; <%= Date.current.year %> AQVC Hub. All rights reserved.</p>
  </div>
</div>
